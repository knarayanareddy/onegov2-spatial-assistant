# ──────────────────────────────────────────────────────────────────────────────
# LLM
# ──────────────────────────────────────────────────────────────────────────────
# Default: OpenAI public API. The repo uses the OpenAI-compatible API, so any
# OpenAI-compatible endpoint works.
#
# GreenPT (offered to OneGov #2 hackathon teams by Provincie Zuid-Holland):
# replace OPENAI_KEY and OPENAI_MODEL below with your GreenPT credentials,
# and uncomment OPENAI_BASE_URL with the GreenPT endpoint. See docs.greenpt.ai.
OPENAI_KEY=""
OPENAI_MODEL="gpt-5-chat"
# OPENAI_BASE_URL="https://api.greenpt.ai/v1"

# ──────────────────────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────────────────────
PORT=8000
DEBUG=false
# Second assignment wins; "*" is convenient for local dev.
ALLOWED_ORIGINS="http://localhost:5173"
ALLOWED_ORIGINS="*"

# ──────────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://ruimtelijke:secret123!@localhost:5432/sessions"
